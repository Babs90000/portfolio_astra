---
import ProjectCard from './ProjectCard.astro';

const projects = [
    { image: "/images/taller.webp", url: "https://taller.com", tags: ["PHP", "MySQL", "Responsive"], index: 0 },
    { image: "/images/asiria.webp", url: "https://asiriaalvarez.art", tags: ["HTML/CSS", "JavaScript", "Galería"], index: 1 },
    { image: "/images/sout-doramas.webp", url: "https://sout-doramas.kdevs.io", tags: ["PHP", "MySQL", "Eventos"], index: 2 },
    { image: "/images/zoo-arcadia.webp", url: "https://zoo-arcadia.babou.dev/", tags: ["PHP", "MySQL", "CRUD", "Admin"], index: 3 },
    { image: "/images/simulator.webp", url: "https://simulator.babou.dev/", tags: ["React", "JavaScript", "Hooks"], index: 4 },
    { image: "/images/todolist.webp", url: "#", tags: ["React", "Hooks", "Estado"], index: 5, isCode: true }
];
---
<style>
    .projects-section { max-width: 1200px; margin: 0 auto; padding: 6rem 2rem; position: relative; z-index: 1; }
    .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; }
</style>

<section class="projects-section" id="projects">
    <h2 class="section-title animate-on-scroll" data-i18n="projects.title">Mis Proyectos</h2>
    <div class="projects-grid">
        {projects.map(p => <ProjectCard {...p} />)}
    </div>
</section>
